// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


// Setup
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// Enums 
enum Role {
  ADMIN
  CUSTOMER
}

enum ProductType {
  FILE
  COURSE
  SUBSCRIPTION
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
}

// User
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cart   Cart?
  orders Order[]
  libraryItems LibraryItem[]
  subscriptions Subscription[]
}

//Category 
model Category {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

// Product
model Product {
  id          String      @id @default(uuid())
  categoryId  String
  name        String
  description String?
  price       Int
  productType ProductType @default(FILE)
  imageUrl    String?
  downloadUrl String?
  accessUrl   String?     // For COURSE or SUBSCRIPTION external links
  accessExpiryDays Int?   // Optional time-limited access (days). Null => perpetual access
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  category   Category   @relation(fields: [categoryId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]
  libraryItems LibraryItem[]
  subscriptions Subscription[]
}

// Cart
model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]
}

// CartItems
model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

// Order
model Order {
  id          String       @id @default(uuid())
  userId      String
  totalAmount Int
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
  payment Payment?
  subscriptions Subscription[]
}

// OrderItems
model OrderItem {
  id        String   @id @default(uuid())
  orderId  String
  productId String
  quantity Int
  price    Int
  createdAt DateTime @default(now())

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  libraryItem LibraryItem?
}

// Payment
model Payment {
  id            String         @id @default(uuid())
  orderId       String         @unique
  paymentMethod String
  invoiceId     String?
  paymentUrl    String?
  status        PaymentStatus  @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  order Order @relation(fields: [orderId], references: [id])
}

// Library entitlement (explicit library table)
// One entitlement per (userId, productId), deduped; purchase history remains in order/orderItem.
model LibraryItem {
  id String @id @default(uuid())

  userId    String
  productId String

  // Link the entitlement to the purchase record that granted it.
  // This is unique to keep one-to-one mapping with an OrderItem.
  orderItemId String @unique

  purchasedAt DateTime
  expiresAt   DateTime? // null => perpetual

  // Snapshots help prevent access URLs changing after purchase.
  accessUrlSnapshot   String?
  downloadUrlSnapshot String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User      @relation(fields: [userId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// Subscription entitlement wrapper for products of type SUBSCRIPTION.
model Subscription {
  id String @id @default(uuid())

  userId    String
  productId String
  orderId   String

  startsAt DateTime
  endsAt   DateTime?
  status   SubscriptionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}


